<style>
  :root {
    --black: #000000;
    --white: #FFFFFF;
    --border: #E5E5E5;
    --text-muted: #999999;
  }

  body {
    margin: 0;
    padding: 0;
    font-family: 'Inter', -apple-system, sans-serif;
    background-color: var(--white);
    color: var(--black);
    -webkit-font-smoothing: antialiased;
  }

  /* Navigation */
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background-color: var(--white);
    border-bottom: 1px solid var(--border);
    padding: 12px 24px;
  }

  .nav-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    text-decoration: none;
    color: var(--black);
  }

  .nav-btn {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background-color: var(--black);
    color: var(--white);
    padding: 8px 16px;
    text-decoration: none;
  }

  /* Hero */
  .hero-section {
    margin-top: 56px;
    position: relative;
    width: 100%;
    height: 90vh;
    background-color: var(--black);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.2);
  }

  .hero-content {
    position: relative;
    z-index: 10;
    padding: 0 32px;
    width: 80%;
    max-width: 1000px;
  }

  .hero-text {
    color: var(--white);
    font-size: clamp(2rem, 5vw, 4rem);
    line-height: 0.9;
    letter-spacing: -0.02em;
    font-weight: 500;
    text-transform: uppercase;
    text-align: center;
    margin: 0;
  }

  /* Marquee */
  .marquee-section {
    padding: 16px 0;
    overflow: hidden;
    background-color: var(--white);
    border-bottom: 1px solid var(--border);
  }

  .marquee-track {
    display: flex;
    white-space: nowrap;
    font-size: clamp(3rem, 12vw, 140px);
    line-height: 0.875;
    letter-spacing: -0.02em;
    font-weight: 400;
    width: fit-content;
    animation: marquee 15s linear infinite;
  }

  .marquee-items {
    display: inline-flex;
    gap: 0.5em;
    padding-right: 0.5em;
  }

  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* Pricing Section */
  .pricing-section {
    padding: 32px 0 40px 0;
    background-color: var(--black);
    color: var(--white);
  }

  .section-header {
    padding: 0 16px;
    margin-bottom: 24px;
  }

  .massive-title {
    margin: 0;
    font-size: clamp(3rem, 12vw, 140px);
    line-height: 0.875;
    letter-spacing: -0.02em;
    font-weight: 400;
    text-transform: uppercase;
  }

  .section-subtitle {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: 16px;
  }

  .cards-scroll {
    display: flex;
    gap: 12px;
    padding: 0 16px;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .cards-scroll::-webkit-scrollbar {
    display: none;
  }

  .product-card {
    flex-shrink: 0;
    width: 85vw;
    max-width: 500px;
  }

  .card-link {
    display: block;
    position: relative;
    overflow: hidden;
    border: 1px solid var(--border);
  }

  .card-image-wrapper {
    position: relative;
    width: 100%;
    padding-bottom: 125%;
  }

  .bg-dark { background-color: #111; }
  .bg-light { background-color: #EFEFEF; }

  .card-gradient {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 50%;
    background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0) 100%);
    pointer-events: none;
  }

  .card-text-container {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 24px;
  }

  .card-title {
    color: var(--white);
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 6vw, 3.5rem);
    font-weight: 400;
    text-transform: uppercase;
    line-height: 1;
    margin: 0 0 8px 0;
  }

  .card-subtitle {
    color: var(--white);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0;
  }

  .text-black { color: var(--black) !important; }

  .card-action-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px 0;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--white);
    background-color: var(--black);
    text-decoration: none;
    border: 1px solid var(--white);
    margin-top: 8px;
  }

  /* Testimonial Quote */
  .quote-section {
    padding: 80px 24px;
    background-color: var(--white);
    color: var(--black);
  }

  .quote-container {
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
  }

  .quote-text {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.25rem, 7vw, 5rem);
    line-height: 1.15;
    letter-spacing: -0.025em;
    margin: 0;
  }

  .quote-author {
    margin-top: 32px;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
  }

  /* Footer CTA */
  .footer-cta-section {
    background-color: var(--black);
    padding: 100px 24px;
    text-align: center;
  }

  .footer-cta-link {
    display: inline-block;
    color: var(--white);
    font-size: clamp(3rem, 12vw, 140px);
    line-height: 1;
    letter-spacing: -0.02em;
    font-weight: 400;
    text-transform: uppercase;
    text-decoration: underline;
  }

  /* Footer Bottom */
  .main-footer {
    border-top: 1px solid var(--border);
    padding: 24px;
    background-color: var(--white);
  }

  .footer-bottom {
    display: flex;
    flex-direction: column;
    gap: 8px;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
  }

  @media (min-width: 768px) {
    .product-card { width: 45vw; }
    .footer-bottom { 
      flex-direction: row; 
      justify-content: space-between;
    }
    .align-right { text-align: right; }
  }
</style>
</html>
  </div>
</section>

<!-- STATS BAR -->
<div class="proof-bar">
  <div class="proof-item">
    <span class="proof-number">500+</span>
    <span class="proof-label">Pelanggan</span>
  </div>
  <div class="proof-item">
    <span class="proof-number">4.9★</span>
    <span class="proof-label">Rating Shopee</span>
  </div>
  <div class="proof-item">
    <span class="proof-number">iOS</span>
    <span class="proof-label">Platform</span>
  </div>
  <div class="proof-item">
    <span class="proof-number">&lt;10 mnt</span>
    <span class="proof-label">Aktivasi</span>
  </div>
</div>

<!-- FEATURES -->
<section>
  <p class="section-label">Apa yang kamu dapat</p>
  <h2 class="section-title">Semua tools untuk foto<br /><em>yang terasa mahal.</em></h2>
  <div class="features-grid">
    {features.map(f => (
      <div class="feature-card">
        <span class="feature-icon">{f.icon}</span>
        <div class="feature-title">{f.title}</div>
        <div class="feature-desc">{f.desc}</div>
      </div>
    ))}
  </div>
</section>

<div class="divider"><span>Perbandingan</span></div>

<!-- COMPARISON -->
<section>
  <p class="section-label">Labbet gratis vs premium</p>
  <h2 class="section-title">Seberapa beda<br /><em>versi premium?</em></h2>
  <div class="comparison-wrapper">
    <table class="comparison-table">
      <thead>
        <tr>
          <th>Fitur</th>
          <th>Gratis</th>
          <th>✦ Premium</th>
        </tr>
      </thead>
      <tbody>
        <tr>

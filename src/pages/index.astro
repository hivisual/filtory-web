<style>
  :root {
    --black: #000000;
    --white: #FFFFFF;
    --light: #F5F5F5;
    --border: #E5E5E5;
    --text-muted: #737373;
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    padding: 0;
    font-family: 'Inter', -apple-system, sans-serif;
    background-color: var(--white);
    color: var(--black);
    -webkit-font-smoothing: antialiased;
    line-height: 1.5;
  }

  /* Utility Classes */
  .bg-black { background-color: var(--black); }
  .bg-light { background-color: var(--light); }
  .text-white { color: var(--white) !important; }
  .text-muted { color: var(--text-muted); }
  .font-bold { font-weight: 600; }
  .w-full { width: 100%; text-align: center; }
  .justify-center { justify-content: center; }
  .border-bottom { border-bottom: 1px solid var(--border); }

  /* Navigation */
  .navbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 50;
    background-color: var(--white);
    border-bottom: 1px solid var(--border);
    padding: 16px 24px;
  }

  .nav-content { display: flex; justify-content: space-between; align-items: center; }
  .logo { font-size: 1.25rem; font-weight: 600; letter-spacing: -0.02em; text-decoration: none; color: var(--black); }
  .nav-btn { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; background-color: var(--black); color: var(--white); padding: 10px 20px; text-decoration: none; }

  /* Hero */
  .hero-section {
    margin-top: 60px;
    padding: 100px 24px;
    text-align: center;
    border-bottom: 1px solid var(--border);
  }

  .hero-container { max-width: 1000px; margin: 0 auto; }
  
  .hero-label {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 24px;
    color: var(--text-muted);
  }

  .massive-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(3rem, 10vw, 7rem);
    line-height: 0.9;
    letter-spacing: -0.02em;
    font-weight: 400;
    text-transform: uppercase;
    margin: 0 0 32px 0;
  }

  .hero-desc {
    font-size: clamp(1rem, 3vw, 1.25rem);
    color: var(--text-muted);
    max-width: 600px;
    margin: 0 auto 48px auto;
  }

  /* Buttons */
  .cta-group { display: flex; gap: 16px; flex-wrap: wrap; justify-content: center; }
  
  .btn {
    display: inline-block;
    padding: 16px 32px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    transition: all 0.2s;
  }

  .btn-black { background-color: var(--black); color: var(--white); }
  .btn-outline { background-color: transparent; color: var(--black); border: 1px solid var(--black); }
  .btn-white { background-color: var(--white); color: var(--black); }
  .btn-outline-white { background-color: transparent; color: var(--white); border: 1px solid var(--white); }
  
  .btn:hover { opacity: 0.8; }

  /* Stats Section */
  .stats-section {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    border-bottom: 1px solid var(--black);
  }

  .stat-item {
    padding: 32px 24px;
    text-align: center;
    border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .stat-value {
    display: block;
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 400;
    letter-spacing: -0.04em;
    line-height: 1;
    margin-bottom: 8px;
  }

  .stat-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
  }

  /* Universal Content Layout */
  .content-section { padding: 80px 24px; }
  .section-grid { display: grid; grid-template-columns: 1fr; gap: 48px; max-width: 1200px; margin: 0 auto; }
  
  .label-text {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin: 0 0 16px 0;
  }

  .large-heading {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1;
    letter-spacing: -0.02em;
    font-weight: 400;
    text-transform: uppercase;
    margin: 0;
  }

  /* Features Grid */
  .features-grid { display: grid; grid-template-columns: 1fr; gap: 40px; }
  .feature-icon { font-size: 2rem; margin-bottom: 16px; }
  .feature-title { font-size: 1.25rem; font-weight: 600; text-transform: uppercase; margin: 0 0 8px 0; }
  .feature-desc { color: var(--text-muted); margin: 0; }

  /* Comparison Table */
  .comparison-table { width: 100%; border-top: 2px solid var(--black); }
  .table-row { display: grid; grid-template-columns: 2fr 1fr 1fr; padding: 20px 0; border-bottom: 1px solid var(--border); }
  .table-head { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); border-bottom: 2px solid var(--black); }

  /* Steps Grid */
  .steps-grid { display: grid; grid-template-columns: 1fr; gap: 24px; }
  .step-card { padding: 32px; border: 1px solid var(--border); display: flex; flex-direction: column; }
  .step-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px; border-bottom: 1px solid var(--border); padding-bottom: 16px; }
  .step-num { font-family: 'Playfair Display', serif; font-size: 2rem; }
  .step-badge { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.1em; background: var(--black); color: var(--white); padding: 4px 8px; }
  .step-title { font-size: 1.25rem; margin: 0 0 16px 0; text-transform: uppercase; }
  .step-list { margin: 0 0 32px 0; padding-left: 20px; color: var(--text-muted); flex-grow: 1; }
  .step-list li { margin-bottom: 8px; }
  .step-price { font-size: 1.5rem; font-weight: 600; text-align: center; margin-bottom: 16px; }

  /* Reviews */
  .reviews-grid { display: grid; grid-template-columns: 1fr; gap: 24px; }
  .review-card { padding: 32px; border: 1px solid var(--border); }
  .review-stars { font-size: 1.25rem; letter-spacing: 0.1em; margin-bottom: 16px; }
  .review-text { font-family: 'Playfair Display', serif; font-size: 1.5rem; line-height: 1.3; margin: 0 0 24px 0; }
  .review-author { display: flex; flex-direction: column; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; }
  .author-source { color: var(--text-muted); margin-top: 4px; }

  /* FAQ */
  .faq-list { border-top: 2px solid var(--black); }
  .faq-item { padding: 32px 0; border-bottom: 1px solid var(--border); }
  .faq-q { font-size: 1.25rem; font-weight: 600; margin: 0 0 12px 0; }
  .faq-a { color: var(--text-muted); margin: 0; }

  /* Footer CTA */
  .footer-cta-section { padding: 120px 24px; text-align: center; }
  .footer-cta-content { max-width: 900px; margin: 0 auto; }
  .footer-cta-desc { color: #A3A3A3; margin: 0 auto 48px auto; font-size: 1.25rem; }

  /* Footer Bottom */
  .main-footer { padding: 24px; border-top: 1px solid var(--border); }
  .footer-bottom { display: flex; flex-direction: column; gap: 8px; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); }

  /* Desktop Adjustments */
  @media (min-width: 768px) {
    .stats-section { grid-template-columns: repeat(4, 1fr); border-bottom: none; }
    .stat-item { border-bottom: none; border-top: 1px solid var(--black); border-bottom: 1px solid var(--black); }
    .stat-item:last-child { border-right: none; }
    
    .section-grid { grid-template-columns: 1fr 2fr; }
    .section-title-col { position: sticky; top: 100px; align-self: start; }
    
    .features-grid { grid-template-columns: repeat(2, 1fr); }
    .steps-grid { grid-template-columns: repeat(2, 1fr); }
    .reviews-grid { grid-template-columns: repeat(2, 1fr); }
    
    .footer-bottom { flex-direction: row; justify-content: space-between; }
    .align-right { text-align: right; }
  }
</style>
</html>
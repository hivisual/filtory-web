---
const { frontmatter } = Astro.props;
---

<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{frontmatter.title} - Filtory</title>
    <meta name="description" content={frontmatter.description} />
  </head>
  <body class="bg-slate-50 text-slate-900 font-sans antialiased">
    <main class="max-w-3xl mx-auto px-6 pt-12 pb-24">
      <nav class="mb-12">
        <a href="/" class="text-yellow-600 font-bold hover:text-yellow-700 transition-colors">
          &larr; Kembali ke Filtory
        </a>
      </nav>
      <article class="content-wrapper">
        <h1 class="text-3xl md:text-5xl font-extrabold tracking-tight mb-8 leading-tight">
          {frontmatter.title}
        </h1>
        <div class="leading-relaxed space-y-6 text-lg text-slate-700">
          <slot />
        </div>
      </article>
    </main>
    
    <!-- Bottom CTA khusus Artikel SEO -->
    <div class="max-w-3xl mx-auto px-6 pb-12">
      <div class="bg-yellow-100 p-8 rounded-3xl text-center border border-yellow-200">
        <h3 class="text-xl font-bold mb-4">Akses Labbet Premium Sekarang</h3>
        <a href="https://wa.me/62816957050?text=Halo%20Filtory,%20saya%20mau%20beli%20Labbet%20Premium%20via%20QRIS%20(Rp50.000)" class="inline-block bg-yellow-400 font-bold px-8 py-4 rounded-2xl text-slate-900 shadow-sm hover:bg-yellow-500">Beli via WA (Rp50.000)</a>
      </div>
    </div>
  </body>
</html>

<style is:global>
  /* Styling otomatis untuk elemen HTML hasil ketikan Markdown */
  .content-wrapper h2 { font-size: 1.5rem; font-weight: 800; margin-top: 2rem; margin-bottom: 1rem; color: #0f172a; }
  .content-wrapper h3 { font-size: 1.25rem; font-weight: 700; margin-top: 1.5rem; margin-bottom: 0.75rem; color: #0f172a; }
  .content-wrapper p { margin-bottom: 1.25rem; }
  .content-wrapper ul { list-style-type: disc; padding-left: 1.5rem; margin-bottom: 1.25rem; }
  .content-wrapper li { margin-bottom: 0.5rem; }
  .content-wrapper strong { color: #0f172a; }
</style>
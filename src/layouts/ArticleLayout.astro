---
const { frontmatter } = Astro.props;
const WA_LINK = "https://wa.me/62816957050?text=Halo%20Filtory%2C%20saya%20mau%20beli%20Labbet%20Premium%20(Rp50.000)";
const SHOPEE_LINK = "https://s.shopee.co.id/1gG3IthAYI";
---

<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{frontmatter.title} — Filtory</title>
  <meta name="description" content={frontmatter.description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --cream: #F5F0E8;
      --warm-white: #FDFAF5;
      --ink: #1A1612;
      --ink-light: #4A443C;
      --ink-muted: #8A8078;
      --gold: #C9A84C;
      --gold-light: #E8D5A3;
      --gold-pale: #F7EDD4;
      --border: rgba(26,22,18,0.1);
      --border-strong: rgba(26,22,18,0.2);
    }
    body {
      background: var(--warm-white);
      color: var(--ink);
      font-family: 'DM Sans', sans-serif;
      font-weight: 300;
      line-height: 1.7;
    }
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 9999;
      opacity: 0.5;
    }
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      padding: 20px 32px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: rgba(253,250,245,0.9);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
    }
    .nav-logo {
      font-family: 'Playfair Display', serif;
      font-size: 18px;
      color: var(--ink);
      text-decoration: none;
    }
    .nav-cta {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--ink);
      color: var(--warm-white);
      font-size: 13px;
      font-weight: 500;
      padding: 10px 20px;
      border-radius: 100px;
      text-decoration: none;
    }
    article {
      max-width: 680px;
      margin: 0 auto;
      padding: 120px 24px 64px;
    }
    .article-label {
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 16px;
    }
    h1 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(32px, 5vw, 52px);
      font-weight: 700;
      line-height: 1.1;
      color: var(--ink);
      margin-bottom: 24px;
      letter-spacing: -0.02em;
    }
    .article-meta {
      font-size: 13px;
      color: var(--ink-muted);
      margin-bottom: 48px;
      padding-bottom: 32px;
      border-bottom: 1px solid var(--border);
    }
    .prose h2 {
      font-family: 'Playfair Display', serif;
      font-size: 26px;
      font-weight: 700;
      color: var(--ink);
      margin: 48px 0 16px;
      letter-spacing: -0.01em;
    }
    .prose h3 {
      font-size: 18px;
      font-weight: 500;
      color: var(--ink);
      margin: 32px 0 12px;
    }
    .prose p {
      font-size: 17px;
      line-height: 1.8;
      color: var(--ink-light);
      margin-bottom: 20px;
    }
    .prose ul, .prose ol {
      margin: 0 0 20px 24px;
      font-size: 17px;
      color: var(--ink-light);
      line-height: 1.8;
    }
    .prose li { margin-bottom: 6px; }
    .prose strong { color: var(--ink); font-weight: 500; }
    .prose em { font-style: italic; color: var(--ink-muted); }
    .prose hr {
      border: none;
      border-top: 1px solid var(--border);
      margin: 48px 0;
    }
    .cta-box {
      background: var(--ink);
      border-radius: 20px;
      padding: 40px 32px;
      text-align: center;
      margin: 48px 0;
    }
    .cta-box-title {
      font-family: 'Playfair Display', serif;
      font-size: 24px;
      font-weight: 700;
      color: var(--warm-white);
      margin-bottom: 8px;
    }
    .cta-box-sub {
      font-size: 14px;
      color: rgba(255,255,255,0.5);
      margin-bottom: 24px;
    }
    .cta-btns { display: flex; flex-wrap: wrap; gap: 10px; justify-content: center; }
    .cta-btn-wa {
      display: inline-block;
      background: var(--gold);
      color: var(--ink);
      font-weight: 500;
      font-size: 14px;
      padding: 13px 24px;
      border-radius: 100px;
      text-decoration: none;
    }
    .cta-btn-shopee {
      display: inline-block;
      background: transparent;
      color: rgba(255,255,255,0.6);
      font-size: 14px;
      padding: 13px 24px;
      border-radius: 100px;
      border: 1px solid rgba(255,255,255,0.15);
      text-decoration: none;
    }
    footer {
      border-top: 1px solid var(--border);
      padding: 32px 24px;
      text-align: center;
      font-size: 13px;
      color: var(--ink-muted);
    }
    footer a { color: var(--ink-muted); text-decoration: none; }
    @media (max-width: 640px) { nav { padding: 16px 20px; } }
  </style>
</head>
<body>
  <nav>
    <a href="/" class="nav-logo">Filtory</a>
    <a href={WA_LINK} target="_blank" class="nav-cta">Beli Sekarang</a>
  </nav>

  <article>
    <p class="article-label">Panduan · Filtory</p>
    <h1>{frontmatter.title}</h1>
    <div class="article-meta">{frontmatter.date} · Dibaca 3 menit</div>

    <div class="prose">
      <slot />
    </div>

    <div class="cta-box">
      <div class="cta-box-title">Siap akses Labbet Premium?</div>
      <div class="cta-box-sub">Aktivasi instan, panduan lengkap, 500+ pembeli puas.</div>
      <div class="cta-btns">
        <a href={WA_LINK} target="_blank" class="cta-btn-wa">Beli via WA · Rp50.000</a>
        <a href={SHOPEE_LINK} target="_blank" class="cta-btn-shopee">Shopee · Rp59.000</a>
      </div>
    </div>
  </article>

  <footer>
    <a href="/">← Kembali ke Filtory</a>
    <span style="margin: 0 16px; opacity:0.3;">·</span>
    © 2026 Filtory
  </footer>
</body>
</html>